# mise.local.toml.example — template for operator secrets.
#
#   cp mise.local.toml.example mise.local.toml
#   # then replace every CHANGEME with a real value
#
# mise.local.toml is gitignored and overrides/extends mise.toml [env].
# NEVER commit mise.local.toml. This .example carries placeholders only.

[env]
# --- Tofu / provider secrets (PROXMOX_VE_* scheme) ---
# The Tofu provider authenticates with a root@pam login TICKET
# (username + password) — NOT an API token. The Plex CT configures LXC device
# passthrough (dev[n] keys), which Proxmox refuses through ANY API token, even a
# root@pam-owned one; it demands a real root@pam login ticket. bpg auth modes are
# mutually exclusive and the API token takes PRECEDENCE: if PROXMOX_VE_API_TOKEN
# is set, bpg uses the token for ALL API calls and never builds the ticket, so
# the passthrough create 403s. Therefore PROXMOX_VE_API_TOKEN is intentionally
# absent here — set only the username/password ticket below. (The Packer build
# uses its own separate PROXMOX_TOKEN_* token scheme further down — DEC-001.)
PROXMOX_VE_USERNAME = "root@pam"        # MUST be root@pam for device passthrough
PROXMOX_VE_PASSWORD = "CHANGEME"        # the root@pam account password
PROXMOX_VE_SSH_USERNAME = "CHANGEME"    # SSH user for idmap / bind mounts (e.g. root)
CLOUDFLARE_DNS_API_TOKEN = "CHANGEME"   # Zone:DNS:Edit — Traefik DNS-01 (later)

# --- Operator SSH key for the service CTs (Tofu, TF_VAR_* scheme) ---
# Injected into every service CT's root user_account so Ansible's `root@<ct>`
# SSH login works. Without it the CTs have NO root credential and `just play`
# fails with "Permission denied (publickey,password)" (DEBUG.md). Set EITHER a
# .pub file path OR a JSON list of literal keys (read natively as TF_VAR_*):
TF_VAR_operator_ssh_public_key_file = "CHANGEME"  # e.g. /home/you/.ssh/id_ed25519.pub
# TF_VAR_operator_ssh_public_keys   = '["ssh-ed25519 AAAA... you@host"]'

# --- Ansible Vault ---
# Password that decrypts ansible/group_vars/vault.yml (resolved by
# ansible/vault-pass.sh). The shipped vault.yml holds placeholders only and is
# encrypted with the bootstrap password "CHANGEME"; set your own value here and
# `ansible-vault rekey ansible/group_vars/vault.yml` before storing real secrets.
ANSIBLE_VAULT_PASSWORD = "CHANGEME"

# --- Packer secrets (PROXMOX_* scheme) — DEC-001 ---
# scripts/build_template.sh pre-flights these four and exits 78 if any is unset;
# it re-exports them as PKR_VAR_proxmox_*. Keep the names exactly as-is.
PROXMOX_HOST = "CHANGEME"               # e.g. https://pve.home.arpa:8006/
PROXMOX_USER = "CHANGEME"               # e.g. root@pam
PROXMOX_TOKEN_ID = "CHANGEME"           # e.g. root@pam!packer-token
PROXMOX_TOKEN_SECRET = "CHANGEME"       # the token UUID secret
