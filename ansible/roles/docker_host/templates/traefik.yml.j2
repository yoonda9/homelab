# {{ ansible_managed }}
# Traefik static configuration (design §4.4). Entrypoints, providers and the
# single Cloudflare DNS-01 ACME certresolver (le-dns-cf) are defined here; the
# per-router resolver is chosen via the `acme_resolver` group_var (le-dns-cf),
# and staging vs prod issuance is a single `acme_ca_server` toggle (LE staging
# until Step 7). Only DNS-01 can issue the *.{{ domain }} wildcard.
global:
  checkNewVersion: false
  sendAnonymousUsage: false

entryPoints:
  # :80 is the plain-HTTP ingress for the Cloudflare tunnel (cloudflared ->
  # http://traefik:80; TLS is terminated at the Cloudflare edge). It deliberately
  # carries NO entrypoint-level redirect: a global 301 would bounce the tunnel's
  # HTTP request to HTTPS and, because the tunnel re-enters on :80, loop forever.
  # The http->https upgrade is applied PER ROUTER instead — the public plex-web
  # router carries redirect-to-https (dynamic.yml.j2), while the internal <svc>-web
  # routers (compose.yml.j2) serve directly since the edge already did TLS.
  web:
    address: ":80"
  websecure:
    address: ":443"
  # Internal metrics endpoint scraped by Prometheus (Step 10). Not published to
  # the host and never routed — reachable only on the compose network.
  metrics:
    address: ":8082"

providers:
  # Docker labels for the in-compose services (whoami now, extras in Step 10).
  docker:
    exposedByDefault: false
  # File provider for the externally-routed Plex service (Step 9) and the shared
  # middlewares; watched so dynamic config hot-reloads without a restart.
  file:
    directory: /etc/traefik/dynamic
    watch: true

certificatesResolvers:
  # Single resolver: Cloudflare DNS-01 issues the browser-trusted *.{{ domain }}
  # wildcard (HTTP-01 cannot). caServer selects LE staging vs prod via the
  # acme_ca_server toggle — staging for this phase, flipped in Step 7.
  le-dns-cf:
    acme:
      email: "{{ docker_host_acme_email }}"
      storage: /acme.json
      caServer: "{{ acme_ca_server }}"
      dnsChallenge:
        provider: cloudflare
        resolvers:
          - "1.1.1.1:53"
          - "8.8.8.8:53"

api:
  # Dashboard/API served via the routed `api@internal` service only — no insecure
  # :8080 entrypoint. The hardened `traefik-dashboard` file-provider router
  # (dynamic.yml.j2) exposes it on traefik.{{ domain }} behind internal-allowlist.
  dashboard: true

# Prometheus metrics (Step 10), served on the internal `metrics` entrypoint.
metrics:
  prometheus:
    entryPoint: metrics
    addEntryPointsLabels: true
    addServicesLabels: true

log:
  level: INFO
