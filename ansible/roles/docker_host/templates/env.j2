# {{ ansible_managed }}
# Compose env file (mode 0600). The Cloudflare DNS-01 token is sourced from the
# Ansible Vault (group_vars/vault.yml: vault_cloudflare_dns_api_token), never
# committed as a literal. Required by the le-dns-cf resolver after the Step-11
# migration; le-http (HTTP-01) ignores it.
CF_DNS_API_TOKEN={{ vault_cloudflare_dns_api_token | default('') }}
# Grafana admin password (Step 10), sourced from the Ansible Vault
# (group_vars/vault.yml: vault_grafana_admin_password), never a committed literal.
GF_SECURITY_ADMIN_PASSWORD={{ vault_grafana_admin_password | default('') }}
# Cloudflare Tunnel connector token (Step 4), sourced from the Ansible Vault
# (group_vars/vault.yml: vault_cloudflare_tunnel_token), never a committed literal.
# Consumed by the cloudflared service; empty until the operator creates the
# remotely-managed tunnel and stores its token in the vault.
TUNNEL_TOKEN={{ vault_cloudflare_tunnel_token | default('') }}
